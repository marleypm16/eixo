{
  "$schema": "https://biomejs.dev/schemas/1.8.0/schema.json",

  "files": {
    "ignore": ["node_modules", "dist", "build", ".next", "coverage"]
  },

  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },

  "organizeImports": {
    "enabled": true
  },

  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,

      "suspicious": {
        "noExplicitAny": "warn"
      },

      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error"
      },

      "style": {
        "useConst": "error"
      }
    }
  },

  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semi": false,
      "trailingComma": "all",
      "arrowParentheses": "always"
    },

    "linter": {
      "enabled": true,
      "rules": {
        "correctness": {
          "useHookAtTopLevel": "error",
          "useExhaustiveDependencies": "warn"
        },

        "suspicious": {
          "noArrayIndexKey": "warn"
        }
      }
    }
  }
}